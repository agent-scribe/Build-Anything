# ── AI ─────────────────────────────────────────────────────────────
# Required for LIVE generation. Without it, the dashboard runs a built-in
# deterministic demo generator so the whole UI is still explorable.
ANTHROPIC_API_KEY=

# Optional model overrides (sensible defaults are baked in).
WEBUILD_GENERATOR_MODEL=claude-sonnet-4-6
WEBUILD_PLANNER_MODEL=claude-haiku-4-5-20251001

# ── Database (optional in Phase 1) ────────────────────────────────
# Neon, Supabase, or local Postgres. Only needed once you wire persistence.
DATABASE_URL="postgresql://user:password@localhost:5432/webuild?schema=public"

# ── Asset storage (optional in Phase 1) ───────────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
