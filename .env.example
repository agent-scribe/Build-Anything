GITHUB_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI generation
ANTHROPIC_API_KEY=""

# Stripe (for e-commerce checkout)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
